{
  "manifest_version": 3,
  "name": "Link Saver",
  "version": "1.0",
  "description": "A web extension to save commonly accessed links.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  }
}